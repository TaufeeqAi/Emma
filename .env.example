# ── Groq (STT + LLM)
GROQ_API_KEY=your_groq_api_key_here

# ── Qdrant 
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Voice / Audio 
# STT confidence threshold: transcriptions below this ask the patient to repeat.
#   -0.2 = high confidence (clear speech)
#   -0.5 = acceptable
#   -1.0 = low confidence (noisy / unclear)
# Threshold of -0.5 = "ask to repeat if average log-prob below -0.5"
STT_CONFIDENCE_THRESHOLD=-0.5

# Audio sample rate for WebRTC VAD (must be 8000, 16000, 32000, or 48000)
AUDIO_SAMPLE_RATE=16000

# VAD aggressiveness: 0 (least aggressive) to 3 (most aggressive).
# Mode 3 filters background noise aggressively — good for phone audio.
VAD_AGGRESSIVENESS=3

# Minimum audio duration before sending to STT (seconds).
# Too short = incomplete utterances. Too long = unresponsive feel.
MIN_SPEECH_DURATION_SECONDS=0.8

# Silence duration after which we consider the patient has finished speaking.
END_OF_SPEECH_SILENCE_SECONDS=0.8

# Maximum silence before the session sends an "are you still there?" prompt.
MAX_SILENCE_BEFORE_PROMPT_SECONDS=8.0

# TTS speaking rate. 1.0 = normal, 0.9 = slightly slower (clearer for anxious patients)
TTS_SPEAKING_RATE=0.92

# ── Langfuse 
LANGFUSE_PUBLIC_KEY=your_public_key
LANGFUSE_SECRET_KEY=your_secret_key
LANGFUSE_HOST=http://localhost:3001

# ── OpenAI (used by RAGAS + DeepEval as judge LLM) 
OPENAI_API_KEY=your_openai_api_key_here

# ── Evaluation 
# Minimum acceptable RAGAS scores — CI fails below these.
RAGAS_FAITHFULNESS_THRESHOLD=0.80
RAGAS_ANSWER_RELEVANCY_THRESHOLD=0.75
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.70
RAGAS_CONTEXT_RECALL_THRESHOLD=0.70

# ── LiveKit Server 
# Self-hosted: wss://your-livekit-host:7880
# LiveKit Cloud: wss://your-project.livekit.cloud
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Used by agent worker to connect to LiveKit
LIVEKIT_WS_URL=ws://localhost:7880

# ── LiveKit SIP 
# SIP domain LiveKit's SIP bridge listens on (set in livekit.yaml)
LIVEKIT_SIP_DOMAIN=sip.emma-local:5060
# Trunk auth credentials (used in sip_provisioner.py + livekit.yaml)
SIP_AUTH_USERNAME=emma
SIP_AUTH_PASSWORD=change_me_in_production

# ── Webhook Security 
# LiveKit signs webhooks with HMAC-SHA256 using the API secret.
# Set LIVEKIT_WEBHOOK_SECRET = LIVEKIT_API_SECRET (same key by default).
LIVEKIT_WEBHOOK_SECRET=secret

# CORS: frontend origin
CORS_ORIGINS=http://localhost:3000

# ── App 
APP_ENV=development
LOG_LEVEL=INFO